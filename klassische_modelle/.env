# ==========================================
# FOLDER KONFIGURATION
# ==========================================

# Basisverzeichnis für Trainingsdaten
BASE_TRAINING_DIR=./trainings_daten

# Input Ordner(n) - komma-getrennte Liste oder einzelner Ordner
# Beispiel: data_files/c1,data_files/c4,data_files/c6
# oder: data_files/c1
INPUT_FOLDERS=data_files/c1,data_files/c4
WEAR_FILES_FOLDER=wear_files

# Feature Cache
NUMPY_FILES_FOLDER=numpy_files

# Trainierte Modelle und Scaler
OUTPUT_FILES_FOLDER=output_files

# Hinweis: Wear-Datei wird automatisch erkannt!
# Beispiel: Wenn Input-Dateien "c_1_001.csv" heißen,
# wird automatisch "c1_wear.csv" gesucht

# ==========================================
# MODELL KONFIGURATION
# ==========================================

# Random Forest Default Parameter
RF_N_ESTIMATORS=10000
RF_MAX_DEPTH=40

# MLP Default Parameter
MLP_HIDDEN_LAYERS=100,50
MLP_MAX_ITER=1000
MLP_ACTIVATION=relu
MLP_SOLVER=adam

# ==========================================
# DATEN KONFIGURATION
# ==========================================

# Train/Test Split
TEST_SPLIT_RATIO=0.2
RANDOM_STATE=42

# ==========================================
# FEATURE EXTRACTION
# ==========================================

# Sensor Spalten Namen
COLUMN_NAMES=Force_X,Force_Y,Force_Z,Vibration_X,Vibration_Y,Vibration_Z,AE_RMS
